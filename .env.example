# Alpaca API Keys
# Get yours at https://app.alpaca.markets/paper/dashboard/overview  (Paper Trading)
#              https://app.alpaca.markets/live/dashboard/overview    (Live Trading)
#
# Test your keys with curl (must include both auth headers — missing headers = 403):
#   curl -H "APCA-API-KEY-ID: $ALPACA_API_KEY" \
#        -H "APCA-API-SECRET-KEY: $ALPACA_API_SECRET" \
#        https://paper-api.alpaca.markets/v2/account
#
# Or run the built-in validator:
#   python check_auth.py
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Set to "paper" for paper trading (recommended to start), "live" for real money
ALPACA_MODE=paper

# Trading Configuration
INITIAL_CAPITAL=10000.0
MAX_POSITION_PCT=0.05       # Max 5% of portfolio per position
MAX_OPEN_POSITIONS=10       # Max simultaneous open positions
STOP_LOSS_PCT=0.02          # 2% stop-loss per trade
TAKE_PROFIT_PCT=0.06        # 6% take-profit per trade (3:1 R:R)
MAX_DAILY_LOSS_PCT=0.05     # Halt trading if daily loss exceeds 5%

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
