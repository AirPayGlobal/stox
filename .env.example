# Alpaca API Keys
# Get yours at https://alpaca.markets
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Set to "paper" for paper trading (recommended to start), "live" for real money
ALPACA_MODE=paper

# Trading Configuration
INITIAL_CAPITAL=10000.0
MAX_POSITION_PCT=0.05       # Max 5% of portfolio per position
MAX_OPEN_POSITIONS=10       # Max simultaneous open positions
STOP_LOSS_PCT=0.02          # 2% stop-loss per trade
TAKE_PROFIT_PCT=0.06        # 6% take-profit per trade (3:1 R:R)
MAX_DAILY_LOSS_PCT=0.05     # Halt trading if daily loss exceeds 5%

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
