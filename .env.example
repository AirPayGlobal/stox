# ============================== Alpaca ==============================
# Keys: https://app.alpaca.markets  (enable OPTIONS trading on the account!)
# Verify everything with:  python check_auth.py
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_MODE=paper            # "paper" (start here) | "live"

# ========================== Daily governor ==========================
# Hitting the target does NOT stop trading — it arms a trailing floor
# under day P&L. Falling back to the floor banks the day.
DAILY_PROFIT_TARGET=5000     # arms profit protection at this day P&L
PROFIT_FLOOR_PCT=0.70        # always keep >= 70% of the target
PROFIT_GIVEBACK_PCT=0.30     # give back at most 30% of the day's peak
PROTECT_MODE=hold            # hold = stop new entries, open trades run to
                             # their own exits; flatten = close everything
DAILY_MAX_LOSS=1500          # flatten + halt once day P&L <= -this
MAX_TRADES_PER_DAY=12
MAX_CONCURRENT_POSITIONS=3

# ========================== Position sizing =========================
RISK_PER_TRADE_PCT=0.005     # max loss at the stop, as fraction of equity
MAX_PREMIUM_PCT=0.10         # max premium outlay per trade / equity
MAX_CONTRACTS=50

# ============================== Exits ===============================
# (PREMIUM_-prefixed on purpose: the old stock bot's STOP_LOSS_PCT /
#  TAKE_PROFIT_PCT variables must not collide with option exits)
PREMIUM_TARGET_PCT=0.50      # +50% on premium
PREMIUM_STOP_PCT=0.30        # -30% on premium
MAX_HOLD_MINUTES=90

# ========================= Loss discipline ==========================
LOSS_COOLDOWN_MINUTES=30     # no re-entry on an underlying after a loss
WIN_COOLDOWN_MINUTES=10      # short pause after a win (no move-chasing)
MAX_CONSECUTIVE_LOSSES=3     # per underlying per day, then done for the day

# ======================== ORB entry filters =========================
# Independently toggleable (test one at a time via the backtest page).
ORB_FILTER_VWAP=true         # price on the right side of VWAP, slope aligned
ORB_FILTER_RVOL=true         # relative volume vs same time of day
RVOL_MIN=1.3
RVOL_LOOKBACK_DAYS=10
ORB_FILTER_OR_ATR=true       # opening-range size sane vs daily ATR
OR_ATR_MIN=0.30
OR_ATR_MAX=1.00

# ============================ Strategies ============================
STRATEGY=orb                 # orb | sweep | both (sweep benched: live PF 0.99)
# Sweep (liquidity-sweep reversal) settings — see docs/STRATEGIES.md
SWEEP_TIMEFRAME_MINUTES=60   # HTF candle size (240 = true 4-hour)
SWEEP_RR=2.0                 # target = SWEEP_RR x stop distance
SWEEP_TREND_FILTER=false     # require swept candle to close against signal
SWEEP_PREV_DAY_LEVELS=true   # also trade prev-day high/low sweeps
SWEEP_OVERNIGHT_RANGE=true   # also trade overnight/pre-market range sweeps
# Optional ET window redefining that range, e.g. 04:00-09:30 = pre-market
# only (the London-overlap session). Spans midnight if start > end.
# SWEEP_SESSION_WINDOW=04:00-09:30
SWEEP_ENTRY=close            # close | retrace (pullback into FVG/midpoint)
SWEEP_RETRACE_EXPIRY_MIN=60
SWEEP_DISASTER_STOP_PCT=0.60 # premium backstop for sweep trades

# ======================= Contract selection =========================
UNDERLYINGS=SPY              # QQQ benched until it re-qualifies (see docs)
MAX_DTE=1                    # 0 = same-day (0DTE) only
TARGET_DELTA=0.45
MIN_OPEN_INTEREST=100
MAX_SPREAD_PCT=0.10
MIN_BID=0.10

# ============================= Session (ET) =========================
ENTRY_START=09:45
ENTRY_CUTOFF=15:00
FLATTEN_TIME=15:50

# ============================== Engine ==============================
ENGINE_AUTOSTART=true        # engine starts when the server boots
ENGINE_AUTOSTART_DRY=false   # true = auto-start in signals-only dry run

# ============================= Dashboard ============================
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

LOG_LEVEL=INFO

# Where the trade book / day baseline / logs live. Defaults to /data when a
# persistent volume is mounted there (Railway convention), else ./logs.
# STATE_DIR=/data
